# Copy this file to .env and fill in your values.
# cp .env.example .env

# === App ===
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
# Optional: overrides the DSN built from POSTGRES_* vars below
DATABASE_URL=

# === API ===
API_V1_STR=/api/v1
API_PORT=8000

# === PostgreSQL ===
POSTGRES_HOST=localhost
POSTGRES_USER=bookwormhole
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=bookwormhole
POSTGRES_PORT=5432
POSTGRES_ECHO_SQL=true

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === Auth ===
AUTH_SECRET_KEY=change-me-to-a-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=30

# === Encryption (Fernet key for tokens at rest) ===
# 32 url-safe base64-encoded bytes, e.g. `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
ENCRYPTION_KEY=change-me-to-a-real-fernet-key

# === Google OAuth (Drive drive.file scope) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google/callback

# === Testing ===
TEST_DATABASE_URL=postgresql+asyncpg://bookwormhole:secretpassword@localhost:5432/bookwormhole_test

# === Sentry ===
# Blank = disabled (no-op), local dev default
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
